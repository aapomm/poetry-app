<div
  id="<%= dom_id(@game) %>"
  data-controller="game"
  data-game-code-value="<%= @game.code %>"
  data-game-host-value="<%= @game.host == @user_id %>"
  data-game-current-id-value="<%= @user_id %>"

  data-game-ready-url-value="<%= ready_game_path(code: @game.code) %>"
  data-game-start-url-value="<%= start_game_path(code: @game.code) %>"
>
  <%# For rendering lobby/ready views %>
  <%= turbo_stream_from @game %>

  <%# For rendering current/judge views %>
  <%= turbo_stream_from "game_#{@game.id}_user_#{@user_id}" %>

  <turbo-frame id="<%= dom_id(@game, :container) %>">
    <%= yield(@game) %>
  </turbo-frame>
</div>
